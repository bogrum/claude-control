[Desktop Entry]
Type=Application
Version=1.0
Name=Claude Control
GenericName=Claude Code asset manager
Comment=Manage your ~/.claude/ skills, plugins, agents, and commands
# __INSTALL_PATH__ is replaced by install.sh
Exec=__INSTALL_PATH__/.venv/bin/python __INSTALL_PATH__/launcher.py
Icon=__INSTALL_PATH__/assets/icon.png
Terminal=false
Categories=Development;Utility;
StartupNotify=true
Keywords=claude;ai;skills;plugins;dashboard;
